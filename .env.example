# RadScheduler local/operator environment template.
# Do not put service-role secrets in browser code or committed files.

RS_ENVIRONMENT=local
RS_PAGES_URL=http://127.0.0.1:8766
RS_SUPABASE_URL=https://your-production-project.supabase.co
RS_STAGING_SUPABASE_URL=https://your-staging-project.supabase.co

# Optional live E2E account. Use a non-production or staging-only account.
RAD_E2E_EMAIL=
RAD_E2E_PASSWORD=

# Supabase CLI reads its auth token from the local login/keychain.
# Edge function secrets are set with `supabase secrets set`, not here.
