{
  "name": "radscheduler-widget",
  "version": "1.0.6",
  "description": "RadScheduler desktop widget — wRVU goal, scheduled studies, drive-time credit, future PACS integration",
  "main": "src/main.js",
  "author": "RadScheduler",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder -mw",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "org.radsched.widget",
    "productName": "RadScheduler Widget",
    "copyright": "Copyright © RadScheduler",
    "asar": true,
    "files": [
      "src/**/*",
      "build/icon.png",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.medical",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "identity": "-",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RadScheduler Widget"
    },
    "dmg": {
      "title": "RadScheduler Widget",
      "iconSize": 100,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
